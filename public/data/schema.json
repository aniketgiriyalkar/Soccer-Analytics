  "MatchEvent": {
    "additionalProperties": false,
    "properties": {
      "detail": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Detail"
      },
      "event_type": {
        "title": "Event Type",
        "type": "string"
      },
      "id": {
        "title": "Id",
        "type": "string"
      },
      "match_id": {
        "title": "Match Id",
        "type": "string"
      },
      "minute": {
        "maximum": 150,
        "minimum": 0,
        "title": "Minute",
        "type": "integer"
      },
      "player_id": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Player Id"
      },
      "score_state": {
        "anyOf": [
          {
            "pattern": "^(leading|drawing|trailing)$",
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Score State"
      },
      "second": {
        "anyOf": [
          {
            "maximum": 59,
            "minimum": 0,
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Second"
      },
      "team_id": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Team Id"
      }
    },
    "required": [
      "id",
      "match_id",
      "minute",
      "event_type"
    ],
    "title": "MatchEvent",
    "type": "object"
  },
  "MetricCoverage": {
    "$defs": {
      "CoverageLevel": {
        "enum": [
          "complete",
          "partial",
          "unavailable"
        ],
        "title": "CoverageLevel",
        "type": "string"
      }
    },
    "additionalProperties": false,
    "properties": {
      "competition_id": {
        "title": "Competition Id",
        "type": "string"
      },
      "events": {
        "$ref": "#/$defs/CoverageLevel"
      },
      "expected_matches": {
        "anyOf": [
          {
            "minimum": 0,
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Expected Matches"
      },
      "generated_at": {
        "format": "date-time",
        "title": "Generated At",
        "type": "string"
      },
      "ingested_matches": {
        "default": 0,
        "minimum": 0,
        "title": "Ingested Matches",
        "type": "integer"
      },
      "season_id": {
        "title": "Season Id",
        "type": "string"
      },
      "standard_stats": {
        "$ref": "#/$defs/CoverageLevel"
      },
      "xg": {
        "$ref": "#/$defs/CoverageLevel"
      }
    },
    "required": [
      "competition_id",
      "season_id",
      "standard_stats",
      "xg",
      "events",
      "generated_at"
    ],
    "title": "MetricCoverage",
    "type": "object"
  },
