{
  "ManagerTenure": {
    "additionalProperties": false,
    "properties": {
      "end_date": {
        "anyOf": [
          {
            "format": "date",
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "End Date"
      },
      "id": {
        "title": "Id",
        "type": "string"
      },
      "manager_id": {
        "title": "Manager Id",
        "type": "string"
      },
      "manager_name": {
        "title": "Manager Name",
        "type": "string"
      },
      "matches": {
        "default": 0,
        "minimum": 0,
        "title": "Matches",
        "type": "integer"
      },
      "start_date": {
        "format": "date",
        "title": "Start Date",
        "type": "string"
      },
      "team_id": {
        "title": "Team Id",
        "type": "string"
      }
