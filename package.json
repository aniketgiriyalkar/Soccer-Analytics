{
  "name": "football-lab",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "manifest": "node scripts/write-build-manifest.mjs",
    "predev": "npm run manifest",
    "dev": "next dev",
    "prebuild": "npm run manifest",
    "build": "next build",
    "start": "npx serve out",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --test web-tests/*.test.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.9",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
